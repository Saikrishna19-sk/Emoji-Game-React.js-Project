import './index.css'

const WinOrLoseCard = props => {
  const {isWon, score, playAgain} = props

  const headingText = isWon ? 'You Won' : 'You Lose'

  const scoreText = isWon ? 'Best Score' : 'Score'

  const imageUrl = isWon
    ? 'https://assets.ccbp.in/frontend/react-js/won-game-img.png'
    : 'https://assets.ccbp.in/frontend/react-js/lose-game-img.png'

  const finalScore = isWon ? '12/12' : `${score}/12`

  return (
    <div className="result-container">
      <div className="text-container">
        <h1>{headingText}</h1>

        <p>{scoreText}</p>

        <p>{finalScore}</p>

        <button type="button" className="play-again-btn" onClick={playAgain}>
          Play Again
        </button>
      </div>

      <img src={imageUrl} alt="win or lose" className="result-image" />
    </div>
  )
}

export default WinOrLoseCard

